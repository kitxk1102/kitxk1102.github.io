

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>여러 가지 사이트 소개</title>
  <style>
    body {
      font-family: Arial, sans-serif;
      margin: 20px;
    }

    h1 {
      text-align: center;
    }

    .site-container {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
    }

    .site-card {
      width: 300px;
      padding: 20px;
      margin: 10px;
      border: 1px solid #ccc;
      border-radius: 5px;
      text-align: center;
      background-color: #1c4a10;
    }

    .site-title {
      font-size: 20px;
      margin-bottom: 10px;
    }

    .site-description {
      color: #666;
    }

    .site-link {
      text-decoration: none;
      color: #333;
      font-weight: bold;
    }
  </style>
</head>
<body>
  <h1>학급 모시깽 프로그램</h1>

  <div class="site-container">
    <div class="site-card">
      <h2 class="site-title">사이트 1</h2>
      <p class="site-description">사이트 1의 설명 Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
      <a class="site-link" href="http://example.com">사이트 1 바로가기</a>
    </div>

    <div class="site-card">
      <h2 class="site-title">사이트 2</h2>
      <p class="site-description">사이트 2의 설명 Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
      <a class="site-link" href="http://example.com">사이트 2 바로가기</a>
    </div>

    <div class="site-card">
      <h2 class="site-title">사이트 3</h2>
      <p class="site-description">사이트 3의 설명 Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
      <a class="site-link" href="http://example.com">사이트 3 바로가기</a>
    </div>

    <!-- 추가적인 사이트 카드를 필요에 따라 반복하여 추가할 수 있습니다 -->
  </div>
</body>
</html>
